# =============================================================================
# swipenest-broker — .env.local
# Copy this file to .env.local and fill in the values.
# =============================================================================

# AWS region where Kafka EC2 instances are deployed
AWS_REGION=ap-south-1

# Kafka port for VPC-internal connections (INTERNAL listener)
# 19092 = INTERNAL (consumer/admin tools, private IP, used in brokers.json)
# 9092  = CLIENT   (KafkaJS producer from app servers, public IP)
KAFKA_PORT=19092

# Consumer group ID (used by check-data.js to report lag)
KAFKA_GROUP_ID=swipenest-consumer-group
